# GitHub Actions Secrets Template
# Copy this file to a secure location and fill in the values
# DO NOT commit this file with actual values to the repository

# ============================================
# Google Cloud Platform (GCP) Configuration
# ============================================

# Your GCP Project ID (e.g., "cerebro-ai-prod-123456")
GCP_PROJECT_ID=

# GCP Service Account JSON Key (entire JSON content)
# Generate with: gcloud iam service-accounts keys create key.json --iam-account=github-actions@PROJECT_ID.iam.gserviceaccount.com
GCP_SA_KEY=

# GKE Cluster name (e.g., "cerebro-cluster-prod")
GKE_CLUSTER_NAME=

# GCP Zone where GKE cluster is deployed (e.g., "us-central1-a")
GKE_ZONE=

# ============================================
# Package Registry Configuration
# ============================================

# PyPI API Token for publishing packages
# Generate at: https://pypi.org/manage/account/token/
# Scope: Entire account or specific project
PYPI_API_TOKEN=

# Codecov Token for coverage reporting
# Get from: https://app.codecov.io/github/OWNER/REPO/settings
CODECOV_TOKEN=

# ============================================
# Notification Configuration
# ============================================

# Slack Webhook URL for deployment notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
# Format: https://hooks.slack.com/services/TXXXXX/BXXXXX/XXXXX
SLACK_WEBHOOK_URL=

# ============================================
# Optional: Additional Security Tokens
# ============================================

# GitHub Personal Access Token (if needed for cross-repo operations)
# Scopes needed: repo, workflow, packages
# GITHUB_PAT=

# Docker Hub credentials (if using Docker Hub instead of GCR)
# DOCKER_USERNAME=
# DOCKER_PASSWORD=

# SonarCloud Token (if using SonarCloud for code quality)
# SONAR_TOKEN=

# Snyk Token (if using Snyk for vulnerability scanning)
# SNYK_TOKEN=

# ============================================
# Environment-Specific Configurations
# ============================================

# Staging Environment
# STAGING_DATABASE_URL=
# STAGING_REDIS_URL=
# STAGING_TEMPORAL_HOST=

# Production Environment
# PRODUCTION_DATABASE_URL=
# PRODUCTION_REDIS_URL=
# PRODUCTION_TEMPORAL_HOST=

# ============================================
# Instructions for Adding Secrets to GitHub
# ============================================
# 
# 1. Using GitHub CLI:
#    gh secret set SECRET_NAME < secret_value.txt
#
# 2. Using GitHub Web UI:
#    - Go to: https://github.com/OWNER/REPO/settings/secrets/actions
#    - Click "New repository secret"
#    - Enter name and value
#    - Click "Add secret"
#
# 3. Using this template with a script:
#    source .github/secrets.template.env
#    for var in $(grep -E "^[A-Z_]+=" .github/secrets.template.env | cut -d= -f1); do
#      if [ ! -z "${!var}" ]; then
#        echo "${!var}" | gh secret set "$var"
#      fi
#    done
#
# ============================================
# Security Best Practices
# ============================================
#
# 1. Never commit this file with actual values
# 2. Rotate secrets regularly (every 90 days for keys)
# 3. Use least privilege principle for service accounts
# 4. Enable secret scanning in repository settings
# 5. Use environment-specific secrets when possible
# 6. Audit secret usage regularly
# 7. Delete local copies after adding to GitHub
#
# ============================================