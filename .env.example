# Research Platform Environment Variables
# Copy this file to .env and update with your values

# Environment Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=change-me-in-production

# Database Configuration
DATABASE_URL=postgresql+asyncpg://research:research123@localhost:5432/research_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=research_db
DB_USER=research
DB_PASSWORD=research123

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Temporal Configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_PORT=7233

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# MCP Configuration
MCP_PORT=9000
MCP_TOOLS_ENABLED=true
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=9000

# Monitoring Configuration
ENABLE_METRICS=true
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Feature Flags
ENABLE_CACHE=true
ENABLE_RATE_LIMITING=false
MAX_REQUESTS_PER_MINUTE=100

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT Configuration
JWT_SECRET_KEY=dev-secret-key-not-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Worker Configuration
WORKER_CONCURRENCY=10
TASK_TIMEOUT_SECONDS=300

# Instance Information (for production)
INSTANCE_ID=dev-instance
REGION=local
AVAILABILITY_ZONE=local

# Secrets Provider (env, vault, aws_secrets)
SECRETS_PROVIDER=env

# Alert Configuration (optional)
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# Validation
VALIDATE_ENV_VARS=false