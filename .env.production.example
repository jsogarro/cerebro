# Production Environment Variables
# Copy this file to .env.production and update with your production values
# NEVER commit actual production values to version control

# Environment Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=8
SECRET_KEY=<GENERATE-STRONG-SECRET-KEY>

# Database Configuration (Production)
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
DB_HOST=<PRODUCTION-DB-HOST>
DB_PORT=5432
DB_NAME=research_db_production
DB_USER=<PRODUCTION-DB-USER>
DB_PASSWORD=<STRONG-DB-PASSWORD>

# Redis Configuration (Production)
REDIS_URL=redis://:<REDIS_PASSWORD>@<REDIS_HOST>:6379/0
REDIS_HOST=<PRODUCTION-REDIS-HOST>
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<STRONG-REDIS-PASSWORD>

# Temporal Configuration (Production)
TEMPORAL_HOST=<TEMPORAL-CLUSTER-HOST>:7233
TEMPORAL_NAMESPACE=research-platform
TEMPORAL_PORT=7233

# Gemini API Configuration (Production)
GEMINI_API_KEY=<YOUR-PRODUCTION-GEMINI-API-KEY>
GEMINI_MODEL=gemini-pro

# MCP Configuration (Production)
MCP_PORT=9000
MCP_TOOLS_ENABLED=true
MCP_SERVER_HOST=mcp-server
MCP_SERVER_PORT=9000

# Monitoring Configuration (Production)
ENABLE_METRICS=true
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Feature Flags (Production)
ENABLE_CACHE=true
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100

# CORS Configuration (Production)
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# JWT Configuration (Production)
JWT_SECRET_KEY=<GENERATE-STRONG-JWT-SECRET>
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MINUTES=60

# Worker Configuration (Production)
WORKER_CONCURRENCY=20
TASK_TIMEOUT_SECONDS=300

# Instance Information (Production)
INSTANCE_ID=${HOSTNAME}
REGION=us-east-1
AVAILABILITY_ZONE=us-east-1a

# Secrets Provider (Production: use vault or aws_secrets)
SECRETS_PROVIDER=vault
VAULT_URL=https://vault.yourdomain.com
VAULT_TOKEN=<VAULT-ACCESS-TOKEN>

# Alert Configuration (Production)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@yourdomain.com

# Validation (Enable in production)
VALIDATE_ENV_VARS=true

# SSL/TLS Configuration
SSL_CERT_FILE=/etc/ssl/certs/server.crt
SSL_KEY_FILE=/etc/ssl/private/server.key
SSL_CA_FILE=/etc/ssl/certs/ca-bundle.crt

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_S3_BUCKET=research-platform-backups
BACKUP_RETENTION_DAYS=30

# CDN Configuration
CDN_URL=https://cdn.yourdomain.com
CDN_ENABLED=true

# Rate Limiting (Production)
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Security Headers
SECURITY_HEADERS_ENABLED=true
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"

# Audit Logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_FILE=/var/log/research/audit.log

# Performance Settings
ENABLE_RESPONSE_COMPRESSION=true
COMPRESSION_LEVEL=6
ENABLE_HTTP2=true
ENABLE_KEEPALIVE=true
KEEPALIVE_TIMEOUT=75

# Resource Limits
MAX_REQUEST_SIZE=10485760  # 10MB
MAX_UPLOAD_SIZE=104857600  # 100MB
MAX_WEBSOCKET_CONNECTIONS=1000
MAX_CONCURRENT_REQUESTS=500